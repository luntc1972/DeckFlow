{
  "compilerOptions": {
    "target": "es2017",
    "module": "none",
    "declaration": false,
    "outDir": "wwwroot/js",
    "rootDir": "wwwroot/ts",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["wwwroot/ts/**/*.ts"]
}
